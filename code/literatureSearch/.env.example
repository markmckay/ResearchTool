# Copy this file to .env.local and fill in your keys

# Optional shared login for private deployments
# When both are set, the entire app and API are gated behind this login form.
APP_LOGIN_USERNAME=your_username_here
APP_LOGIN_PASSWORD=your_password_here

# Optional extra secret used to derive the auth session cookie.
# If omitted, the password is used as the cookie signing secret.
AUTH_SESSION_SECRET=your_extra_session_secret_here

# AI summarization via OpenRouter
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
# Optional: set a fast/cheap model specifically for relevance scoring. Falls back to OPENROUTER_MODEL if not set.
RELEVANCE_MODEL=google/gemini-flash-1.5

# Optional: override the build label shown in the footer. If omitted, the app falls back to the current git commit SHA.
NEXT_PUBLIC_BUILD_ID=

# IEEE Xplore search — apply for a free key at https://developer.ieee.org
# Everything works without this — IEEE results are just skipped until configured
IEEE_API_KEY=your_ieee_key_here
